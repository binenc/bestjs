{
  "name": "bestjs",
  "version": "0.1.0",
  "description": "A secure-by-default, leak-free-by-construction, fail-fast Bun + NestJS foundation. Rust discipline for TypeScript services.",
  "private": true,
  "license": "MIT",
  "author": "binenc (https://github.com/binenc)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/binenc/bestjs.git"
  },
  "bugs": {
    "url": "https://github.com/binenc/bestjs/issues"
  },
  "homepage": "https://github.com/binenc/bestjs#readme",
  "keywords": [
    "bun",
    "nestjs",
    "typescript",
    "secure-by-default",
    "fail-fast",
    "raii",
    "result-type"
  ],
  "type": "module",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "NODE_ENV=production bun src/main.ts",
    "build": "bun build src/main.ts --target=bun --outdir=dist --minify",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "audit": "bun audit --audit-level=high",
    "check": "bun run typecheck && bun run lint && bun run test && bun run audit"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "express": "5.2.1",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@types/bun": "latest",
    "@types/express": "5.0.0",
    "eslint": "9.18.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "trustedDependencies": [],
  "overrides": {
    "@eslint/plugin-kit": ">=0.3.4"
  }
}
