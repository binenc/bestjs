# bestjs environment.
# Every variable here is validated by src/core/config/env.schema.ts at boot.
# A missing or malformed value makes the process REFUSE TO START with a clear
# message — never a silent misconfiguration discovered in production at 3am.

# --- Runtime ---
NODE_ENV=development           # development | test | production
PORT=3000                      # 1..65535
HOST=0.0.0.0
LOG_LEVEL=info                 # trace | debug | info | warn | error | fatal

# --- Lifecycle / hardening ---
BOOTSTRAP_TIMEOUT_MS=15000     # hard-abort if the app can't construct itself in time
SHUTDOWN_GRACE_MS=10000        # max time to drain in-flight work on SIGTERM
BODY_LIMIT_BYTES=1048576       # 1 MiB request body cap
REQUEST_TIMEOUT_MS=30000

# --- Security ---
# 32+ char secret. Generate: `bun -e "console.log(crypto.randomUUID()+crypto.randomUUID())"`
APP_SECRET=change-me-to-a-long-random-string-min-32-chars
TRUST_PROXY=false              # true only behind a trusted L7 proxy/load balancer
